# Puerto del servidor
PORT=4000

# Seguridad — usa un texto largo y aleatorio en producción
JWT_SECRET=cambia_este_secreto_por_uno_muy_largo_y_aleatorio

# Credenciales del panel admin (se crean al primer arranque)
ADMIN_USER=admin
ADMIN_PASSWORD=rivt2025

# MongoDB Atlas — https://www.mongodb.com/cloud/atlas (plan M0 gratis)
# Formato: mongodb+srv://usuario:clave@cluster0.xxxxx.mongodb.net/rivt?retryWrites=true&w=majority
MONGODB_URI=

# MercadoPago — https://www.mercadopago.com.pe/developers
# Credenciales de prueba empiezan con TEST-, las reales con APP_USR-
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

# Cloudinary — https://cloudinary.com (plan gratis)
# Copia la "API Environment variable" del Dashboard
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=
